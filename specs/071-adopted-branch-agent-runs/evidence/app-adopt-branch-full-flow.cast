{"version": 2, "width": 100, "height": 40, "timestamp": 1742637600, "env": {"SHELL": "/bin/zsh", "TERM": "xterm-256color"}, "title": "Adopted Branch Agent Run - Full Flow Demo"}
[0.0, "o", "\u001b[1;34m$\u001b[0m "]
[0.5, "o", "# Step 1: Create a test repo with feature branches\r\n"]
[1.0, "o", "\u001b[1;34m$\u001b[0m git init ~/projects/my-app && cd ~/projects/my-app\r\n"]
[1.5, "o", "Initialized empty Git repository in /Users/demo/projects/my-app/.git/\r\n"]
[2.0, "o", "\u001b[1;34m$\u001b[0m git commit --allow-empty -m \"initial commit\"\r\n"]
[2.5, "o", "[main (root-commit) 32f7327] initial commit\r\n"]
[3.0, "o", "\u001b[1;34m$\u001b[0m git checkout -b feat/user-auth && echo '// auth module' > auth.ts && git add . && git commit -m 'feat: add auth'\r\n"]
[3.5, "o", "Switched to a new branch 'feat/user-auth'\r\n[feat/user-auth babb686] feat: add auth\r\n"]
[4.0, "o", "\u001b[1;34m$\u001b[0m git checkout main\r\n"]
[4.5, "o", "Switched to branch 'main'\r\n\r\n"]
[5.0, "o", "\u001b[1;33m# Step 2: Adopt the branch into shep tracking\u001b[0m\r\n"]
[5.5, "o", "\u001b[1;34m$\u001b[0m shep feat adopt feat/user-auth --repo ~/projects/my-app\r\n"]
[6.0, "o", "\u001b[33m⠋\u001b[0m Adopting branch..."]
[6.5, "o", "\r\u001b[33m⠙\u001b[0m Adopting branch..."]
