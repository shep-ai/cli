/**
 * @module Shep.Agents.PhaseTiming
 *
 * Timing record for a single agent graph node execution.
 * Tracks start, completion, and duration for each phase
 * of the agent lifecycle. Stored in the phase_timings table.
 */
import "../common/base.tsp";

@doc("Execution record for a single agent graph node. Tracks timing, prompt, token usage, and outcome.")
model PhaseTiming extends BaseEntity {
  @doc("Agent run this timing belongs to")
  agentRunId: string;

  @doc("Graph node name: analyze, requirements, research, plan, implement")
  phase: string;

  @doc("When the phase started executing")
  startedAt: utcDateTime;

  @doc("When the phase finished executing (null if still running)")
  completedAt?: utcDateTime;

  @doc("Duration in milliseconds (computed on completion)")
  durationMs?: int64;

  @doc("When the phase started waiting for user approval (null if no approval needed)")
  waitingApprovalAt?: utcDateTime;

  @doc("Duration in milliseconds the phase waited for user approval (null if no approval needed)")
  approvalWaitMs?: int64;

  @doc("The composed prompt sent to the agent for this phase")
  prompt?: string;

  @doc("Model identifier used for this phase execution")
  modelId?: string;

  @doc("Agent executor type: claude-code, cursor, gemini-cli")
  agentType?: string;

  @doc("Number of input tokens consumed (prompt + context)")
  inputTokens?: int64;

  @doc("Number of output tokens generated by the agent")
  outputTokens?: int64;

  @doc("Execution outcome: success, error, timeout, interrupted")
  exitCode?: string;

  @doc("Error details when exitCode is not success")
  errorMessage?: string;
}
