# Feature flags (set to "true" or "1" to enable)
NEXT_PUBLIC_FLAG_SKILLS=false
NEXT_PUBLIC_FLAG_ENV_DEPLOY=false

# Debug logging (set to "true" or "1" to enable verbose logs in browser console)
NEXT_PUBLIC_DEBUG=false

# Dev server request logging (set to "false" to suppress per-request logs)
NEXT_LOG_REQUESTS=true
