{
  "name": "Cursor CLI",
  "summary": "AI-powered terminal coding agent",
  "description": "Cursor CLI is a terminal-based AI coding agent that brings conversational AI assistance directly to your command line for any IDE or terminal.",
  "tags": ["cli-agent"],
  "author": "Anysphere",
  "website": "https://cursor.com",
  "platforms": ["linux", "darwin", "win32"],
  "iconUrl": "https://cdn.simpleicons.org/cursor",
  "binary": "cursor-agent",
  "packageManager": "curl",
  "commands": {
    "linux": "curl https://cursor.com/install -fsS | bash",
    "darwin": "curl https://cursor.com/install -fsS | bash",
    "win32": "winget install --id Anysphere.Cursor -e --source winget"
  },
  "timeout": 300000,
  "documentationUrl": "https://www.codecademy.com/article/getting-started-with-cursor-cli",
  "verifyCommand": "cursor-agent --version",
  "autoInstall": true,
  "openDirectory": "cd {dir} && exec cursor-agent",
  "spawnOptions": {
    "shell": true,
    "stdio": "inherit",
    "detached": false
  },
  "terminalCommand": {
    "linux": "x-terminal-emulator -e bash -c 'cd {dir} && exec cursor-agent'",
    "darwin": "open -a Terminal.app bash -c 'cd {dir} && exec cursor-agent'"
  }
}
