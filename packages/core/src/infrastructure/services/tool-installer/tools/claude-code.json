{
  "name": "Claude Code",
  "summary": "AI-powered code assistant from Anthropic",
  "description": "Claude Code is an AI-powered code assistant from Anthropic that helps you write, understand, and debug code with advanced AI capabilities.",
  "tags": ["cli-agent"],
  "author": "Anthropic",
  "website": "https://claude.ai/code",
  "platforms": ["linux", "darwin", "win32"],
  "iconUrl": "https://cdn.simpleicons.org/claude",
  "binary": "claude",
  "packageManager": "npm",
  "commands": {
    "linux": "npm install -g @anthropic-ai/claude-code",
    "darwin": "npm install -g @anthropic-ai/claude-code",
    "win32": "npm install -g @anthropic-ai/claude-code"
  },
  "timeout": 300000,
  "documentationUrl": "https://docs.anthropic.com/en/docs/claude-code/overview",
  "verifyCommand": "claude --version",
  "autoInstall": true,
  "openDirectory": {
    "linux": "cd {dir} && exec claude",
    "darwin": "cd {dir} && exec claude",
    "win32": "cd /d {dir} && claude"
  },
  "spawnOptions": {
    "shell": true,
    "stdio": "inherit",
    "detached": false
  },
  "terminalCommand": {
    "linux": "x-terminal-emulator -e bash -c 'cd {dir} && exec claude'",
    "darwin": "osascript -e 'tell application \"Terminal\" to do script \"cd {dir} && exec claude\"'",
    "win32": "start cmd /k \"cd /d {dir} && claude\""
  }
}
