{
  "name": "@shepai/electron",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "electron .",
    "compile": "node scripts/build.mjs",
    "build": "node scripts/build.mjs && electron-builder --publish never",
    "build:mac": "node scripts/build.mjs && electron-builder --mac --publish never",
    "build:win": "node scripts/build.mjs && electron-builder --win --publish never",
    "build:linux": "node scripts/build.mjs && electron-builder --linux --publish never",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "electron-window-state": "^5.0.3",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "better-sqlite3": "^12.6.2",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "js-yaml": "^4.1.1",
    "node-notifier": "^10.0.1",
    "umzug": "^3.8.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "which": "^5.0.0",
    "@langchain/langgraph": "^1.1.4",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@langchain/core": "^1.1.22"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "35.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  }
}
